{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@data/*": [
        "./data/*"
      ],
      "@lib/*": [
        "./lib/*"
      ],
      "@engines/*": [
        "./engines/*"
      ],
      "@theme/*": [
        "./theme/*"
      ],
      "@experience/*": [
        "./experience/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "types/**/*.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "data/**/*.ts",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "engines/**/*.ts",
    "engines/**/*.tsx",
    "theme/**/*.ts",
    "experience/**/*.ts",
    "data/registry.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "jessicakhulaya",
    "lobolojessicaesamuel",
    "jessicaesamueltraditionalwedding"
  ]
}
