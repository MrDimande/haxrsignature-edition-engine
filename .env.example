# Copiar para .env.local â€” nunca commitar

# Supabase (mesma conta que haxrsignature.com)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Evento Â· Despedida de Solteira Â· Jessica Muege
EDITION_EVENT_JESSICA_FAREWELL_ID=
EDITION_EVENT_JESSICA_TRADITIONAL_ID=

# WhatsApp noiva (sĂ³ dĂ­gitos)
NEXT_PUBLIC_EDITION_FAREWELL_WHATSAPP=

# Resend â€” emails RSVP e reservas de presente
RESEND_API_KEY=
RESEND_BRAND_DOMAIN=false

# Cron Vercel â€” lembretes RSVP + export API
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EDITION_CRON_SECRET=

# URL pĂºblica (produĂ§Ă£o)
NEXT_PUBLIC_SITE_URL=https://edition.haxrsignature.com

# Control-plane — ponte Edition ? Core (RSVP)
# local = handleLocalRsvpPost | proxy = encaminha para Core
HAXR_API_BACKEND=local
HAXR_CORE_API_BASE_URL=https://www.haxrsignature.com
# Secret partilhado com o Core — NUNCA NEXT_PUBLIC / NUNCA expor ao browser
HAXR_EDITION_PROXY_SECRET=
# true = se o Core falhar, tenta persistência local (desligar para fail-closed total)
HAXR_PROXY_FALLBACK=false
HAXR_PROXY_TIMEOUT_MS=28000
# Preview-only: optional Vercel Protection Bypass secret (server-only)
# HAXR_CORE_VERCEL_BYPASS_SECRET=